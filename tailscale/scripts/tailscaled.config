#!/system/bin/sh
set -e
DIR=$(dirname "$(realpath "$0")")
# shellcheck source=../settings.sh
. "$DIR"/../settings.sh

quote_value() { printf "%s" "$1" | sed "s/'/'\\''/g; s/^/'/; s/$/'/"; }
write_config() {
  tmp="${TS_CONFIG_FILE}.tmp"
  mkdir -p "$(dirname "$TS_CONFIG_FILE")"
  {
    echo "# Magisk Tailscaled runtime configuration"
    echo "# Edit with tailscaled.config or the WebUI. Values are shell-quoted."
    echo "TS_START_ON_BOOT=$(quote_value "${TS_START_ON_BOOT:-1}")"
    echo "TS_DAEMON_ARGS=$(quote_value "${TS_DAEMON_ARGS:--no-logs-no-support}")"
    echo "TS_UP_ARGS=$(quote_value "${TS_UP_ARGS:---accept-dns=false}")"
    echo "TS_HOSTNAME=$(quote_value "${TS_HOSTNAME:-}")"
    echo "TS_ENABLE_SSH=$(quote_value "${TS_ENABLE_SSH:-0}")"
    echo "TS_EXTRA_UP_ARGS=$(quote_value "${TS_EXTRA_UP_ARGS:-}")"
  } >"$tmp"
  mv -f "$tmp" "$TS_CONFIG_FILE"
  chmod 0600 "$TS_CONFIG_FILE" 2>/dev/null || true
}
json_escape() { sed 's/\\/\\\\/g; s/"/\\"/g' | tr '\n' ' '; }
show_json() {
  printf '{'
  printf '"startOnBoot":"%s",' "${TS_START_ON_BOOT:-1}"
  printf '"daemonArgs":"%s",' "$(printf %s "${TS_DAEMON_ARGS:-}" | json_escape)"
  printf '"upArgs":"%s",' "$(printf %s "${TS_UP_ARGS:-}" | json_escape)"
  printf '"hostname":"%s",' "$(printf %s "${TS_HOSTNAME:-}" | json_escape)"
  printf '"enableSsh":"%s",' "${TS_ENABLE_SSH:-0}"
  printf '"extraUpArgs":"%s"' "$(printf %s "${TS_EXTRA_UP_ARGS:-}" | json_escape)"
  printf '}\n'
}
validate_key() {
  case "$1" in TS_START_ON_BOOT|TS_DAEMON_ARGS|TS_UP_ARGS|TS_HOSTNAME|TS_ENABLE_SSH|TS_EXTRA_UP_ARGS) return 0;; esac
  echo "Unsupported key: $1" >&2; return 1
}
set_key() {
  key="$1"; shift || true; value="$*"; validate_key "$key"
  case "$key" in
    TS_START_ON_BOOT|TS_ENABLE_SSH) case "$value" in 0|1|true|false) ;; *) echo "$key must be 0/1/true/false" >&2; return 1;; esac;;
  esac
  eval "$key=\$value"
  write_config
}
build_up_args() {
  args="${TS_UP_ARGS:-}"
  [ -n "${TS_HOSTNAME:-}" ] && args="$args --hostname=${TS_HOSTNAME}"
  case "${TS_ENABLE_SSH:-0}" in 1|true) args="$args --ssh";; esac
  [ -n "${TS_EXTRA_UP_ARGS:-}" ] && args="$args ${TS_EXTRA_UP_ARGS}"
  printf '%s\n' "$args"
}
case "${1:-get}" in
  get|json) show_json ;;
  init) write_config ;;
  set) shift; [ $# -ge 2 ] || { echo "usage: tailscaled.config set KEY VALUE" >&2; exit 2; }; key="$1"; shift; set_key "$key" "$@" ;;
  up) # shellcheck disable=SC2086
      tailscale up $(build_up_args) ;;
  down) tailscale down ;;
  login) tailscale login ;;
  logout) tailscale logout ;;
  restart) tailscaled.service restart ;;
  cmdline) printf '%s\n' "${TS_DAEMON_CMD}" ;;
  up-args) build_up_args ;;
  *) echo "usage: tailscaled.config {get|set KEY VALUE|init|up|down|login|logout|restart|cmdline|up-args}" >&2; exit 2 ;;
esac
